# Copy this file to `.env.local` and fill in the real values.
# Find them in your Supabase dashboard: Project Settings → API.
#
# URL: looks like https://abcdefgh.supabase.co
# Key: the "anon / public" key (on newer projects it's called the
#      "publishable" key and starts with sb_publishable_...)

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-OR-PUBLISHABLE-KEY
